# Required for Kaggle
KAGGLE_USERNAME=
KAGGLE_KEY=

# Optional — improves Hugging Face rate limits
HF_TOKEN=

# Required for Google Dataset Search
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# Optional — improves Socrata rate limits
SOCRATA_APP_TOKEN=

# Optional — access unpublished datasets on Harvard Dataverse
# DATAVERSE_API_TOKEN=

# ─── Remote deployment (Railway) ─────────────────────────

# PostgreSQL connection string (Railway injects DATABASE_URL automatically)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# OAuth — Auth0 Universal Login (Google + GitHub social connections)
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
# AUTH0_AUDIENCE=

# Legacy direct GitHub OAuth fallback (only used when Auth0 is not configured)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Admin stats endpoint protection
ADMIN_KEY=

# Optional — salt for hashing client IPs when OAuth is off (defaults to ADMIN_KEY or "mobus")
# USER_ID_SALT=

# Public URL (set this on Railway so OAuth callbacks and docs use the public host)
# BASE_URL=https://mobus-production.up.railway.app
